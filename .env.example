# Frontend Perception Engine — local dev template
# Copy to `.env` and fill in values. `.env` is gitignored — never commit secrets.

# ── Google OAuth (Search Console + GA4) — operator only ───────────────────────
# Create OAuth Desktop client: https://console.cloud.google.com/apis/credentials
# Enable: Search Console API + Google Analytics Data API + Google Analytics Admin API
# Google Cloud OAuth — register:
#   JavaScript origin: http://localhost:5000
#   Redirect URI: http://localhost:5000/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_CLIENT_TYPE=web
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Token + site profiles are created automatically by perception_seo_connect (not in .env)
# SEO_GOOGLE_TOKEN_PATH=.cache/seo_google_tokens.json

# Self-hosted LibreCrawl — auto-installed and started as native process (no Docker).
# LIBRECRAWL_BASE_URL=http://localhost:5001

# Advanced overrides only when auto-discovery fails (normally leave blank):
# GA4_PROPERTY_ID=

# Bing Webmaster OAuth — register redirect URI: http://localhost:8787/bing/callback
# BING_WEBMASTER_OAUTH_CLIENT_ID=
# BING_WEBMASTER_OAUTH_CLIENT_SECRET=
# LIBRECRAWL_SESSION_COOKIE=
# LIBRECRAWL_CRAWL_TIMEOUT_S=90

# ── SEO Knowledge Graph persistence ──────────────────────────────────────────
SEO_GRAPH_PATH=.cache/seo_graph.json

# ── Optional ───────────────────────────────────────────────────────────────────
# PAGESPEED_API_KEY=          # remote PSI; local Lighthouse needs Node.js only
# BING_WEBMASTER_API_KEY=     # optional P2 provider

# ── Override .env location (optional) ─────────────────────────────────────────
# FRONTEND_PERCEPTION_ENV_FILE=/absolute/path/to/.env
