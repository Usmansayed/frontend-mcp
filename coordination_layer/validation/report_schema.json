{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CoordinationValidationReport",
  "type": "object",
  "required": ["suite_version", "generated_at", "mode", "workflows", "summary"],
  "properties": {
    "suite_version": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "mode": { "type": "string", "enum": ["simulate", "live"] },
    "summary": {
      "type": "object",
      "properties": {
        "total": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer" },
        "mean_cluster_accuracy": { "type": "number" },
        "mean_playbook_accuracy": { "type": "number" },
        "mean_capability_routing_accuracy": { "type": "number" },
        "total_unnecessary_tool_calls": { "type": "integer" }
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["workflow_id", "title", "metrics", "decisions", "findings"],
        "properties": {
          "workflow_id": { "type": "string" },
          "title": { "type": "string" },
          "metrics": { "$ref": "metrics_schema.json" },
          "decisions": { "type": "array" },
          "findings": { "type": "array" },
          "psm_timeline": { "type": "array" }
        }
      }
    },
    "refinement_opportunities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "workflow_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] },
          "description": { "type": "string" }
        }
      }
    }
  }
}
