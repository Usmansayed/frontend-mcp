{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CoordinationValidationMetrics",
  "type": "object",
  "required": [
    "workflow_id",
    "success",
    "psm_evolution_score",
    "cluster_accuracy",
    "playbook_accuracy",
    "capability_routing_accuracy",
    "step_compilation_accuracy",
    "governor_accuracy",
    "recovery_score",
    "replanning_quality",
    "unnecessary_tool_calls",
    "total_tool_calls",
    "elapsed_ms",
    "failure_recovery_attempted"
  ],
  "properties": {
    "workflow_id": { "type": "string" },
    "success": { "type": "boolean" },
    "psm_evolution_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "cluster_accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
    "playbook_accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
    "capability_routing_accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
    "step_compilation_accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
    "governor_accuracy": { "type": "number", "minimum": 0, "maximum": 1 },
    "recovery_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "replanning_quality": { "type": "number", "minimum": 0, "maximum": 1 },
    "unnecessary_tool_calls": { "type": "integer", "minimum": 0 },
    "total_tool_calls": { "type": "integer", "minimum": 0 },
    "elapsed_ms": { "type": "integer", "minimum": 0 },
    "failure_recovery_attempted": { "type": "boolean" },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
